        {
          "cmd": "undo terminal monitor",
          "short": "undo t m",
          "desc": "关闭终端日志监控，配置前第一步必做",
          "when": "开始配置前"
        },
        {
          "cmd": "system-view",
          "short": "sys",
          "desc": "进入[]系统视图",
          "when": "需要配置设备时"
        },
        {
          "cmd": "display version",
          "desc": "查看设备版本型号",
          "when": "识别设备型号"
