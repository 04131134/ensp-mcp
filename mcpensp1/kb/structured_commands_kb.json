              "desc": "宣告网段"
            },
            {
              "cmd": "default-route-advertise",
              "desc": "向OSPF邻居下发默认路由"
            }
          ],
          "tips": [
            "防火墙通常下发默认路由，让内网交换机通过它访问外网"
          ]
        },
        "静态路由": {
          "view": "[FW]",
          "commands": [
            {
              "cmd": "ip route-static 0.0.0.0 0.0.0.0 <nexthop>",
              "desc": "默认静态路由",
              "example": "ip route-static 0.0.0.0 0.0.0.0 10.0.0.2"
            }
          ]
        },
        "AAA账户": {
