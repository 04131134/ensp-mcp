    "AC6605": {
      "description": "华为AC6605无线控制器",
      "topics": {
        "基础配置": {
          "view": "[AC]",
          "commands": [
            {
              "cmd": "sysname AC",
              "desc": "修改主机名"
            },
            {
              "cmd": "undo info-center enable",
              "desc": "关闭信息中心"
            },
            {
              "cmd": "vlan batch 100 to 101",
              "desc": "创建管理VLAN100和用户VLAN101"
            },
            {
              "cmd": "dhcp enable",
              "desc": "开启DHCP"
            },
            {
              "cmd": "interface Vlanif100",
              "desc": "进入管理VLANIF"
            },
            {
              "cmd": "ip address 192.168.100.1 255.255.255.0",
              "desc": "配置管理VLAN IP"
            },
            {
              "cmd": "dhcp select interface",
              "desc": "接口模式分配IP给AP"
            },
            {
              "cmd": "interface GigabitEthernet0/0/19",
              "desc": "进入上行口"
            },
            {
              "cmd": "port link-type trunk",
              "desc": "trunk模式"
            },
            {
              "cmd": "port trunk allow-pass vlan 2 to 4094",
              "desc": "放行所有VLAN"
            },
            {
              "cmd": "capwap source interface Vlanif100",
              "desc": "指定CAPWAP隧道源接口（AP发现AC的关键）"
            }
          ]
        },
        "WLAN安全配置": {
          "view": "[AC-wlan-view]",
          "commands": [
            {
              "cmd": "wlan",
              "desc": "进入WLAN视图"
            },
            {
              "cmd": "security-profile name <name>",
              "desc": "创建安全配置文件",
              "example": "security-profile name sec"
            },
            {
              "cmd": "security wpa-wpa2 psk pass-phrase <pwd> aes",
              "desc": "WPA2-PSK加密（会弹Y/N确认）"
            },
            {
              "cmd": "quit",
              "desc": "退出安全配置文件"
            }
          ],
          "tips": [
            "security wpa-wpa2命令会弹确认提示[Y/N]，脚本需特殊处理",
            "WLAN子视图层级很深，注意quit退出"
          ]
        },
        "WLAN SSID配置": {
          "view": "[AC-wlan-view]",
          "commands": [
            {
              "cmd": "ssid-profile name <name>",
              "desc": "创建SSID配置文件",
              "example": "ssid-profile name ssid"
            },
            {
              "cmd": "ssid <name>",
              "desc": "设置WiFi名称",
              "example": "ssid wlan-2024"
            },
            {
              "cmd": "quit",
              "desc": "退出SSID配置文件"
            }
          ]
        },
        "WLAN VAP配置": {
          "view": "[AC-wlan-view]",
          "commands": [
            {
              "cmd": "vap-profile name <name>",
              "desc": "创建VAP配置文件",
              "example": "vap-profile name vap"
            },
            {
              "cmd": "service-vlan vlan-id <id>",
              "desc": "WiFi用户VLAN",
              "example": "service-vlan vlan-id 101"
            },
            {
              "cmd": "ssid-profile <name>",
              "desc": "引用SSID配置文件"
            },
            {
              "cmd": "security-profile <name>",
              "desc": "引用安全配置文件"
            },
            {
              "cmd": "quit",
              "desc": "退出VAP配置文件"
            }
          ]
        },
        "WLAN AP组配置": {
          "view": "[AC-wlan-view]",
          "commands": [
            {
              "cmd": "ap-group name <name>",
              "desc": "创建AP分组",
              "example": "ap-group name ap"
            },
            {
              "cmd": "radio 0",
              "desc": "进入射频0（2.4G）"
            },
            {
              "cmd": "vap-profile <name> wlan 1",
              "desc": "绑定VAP到射频",
              "example": "vap-profile vap wlan 1"
            },
            {
              "cmd": "quit",
              "desc": "退出射频"
            },
            {
              "cmd": "radio 1",
              "desc": "进入射频1（5G）"
            },
            {
              "cmd": "quit",
              "desc": "退出AP组"
            }
          ],
          "tips": [
            "radio 0 通常是2.4GHz，radio 1 通常是5GHz",
            "vap-profile绑定后AP才会广播SSID"
          ]
        },
        "AP注册": {
          "view": "[AC-wlan-view]",
          "commands": [
            {
              "cmd": "ap-id <id> ap-mac <mac> ap-sn <sn>",
              "desc": "注册AP（指定ID、MAC、SN）"
            },
            {
              "cmd": "ap-name <name>",
              "desc": "设置AP名称",
              "example": "ap-name ap1"
            },
            {
              "cmd": "ap-group <name>",
              "desc": "将AP加入分组（会弹Y/N确认）",
              "example": "ap-group ap"
            }
          ],
          "tips": [
            "ap-group命令会弹Warning提示[Y/N]，脚本需等待后发送y",
            "AP注册后需等待30-40秒才会正常上线",
            "ap-mac和ap-sn必须与eNSP拓扑中AP的实际值一致"
          ]
        },
        "经验积累": {
          "commands": [
            {
              "cmd": "capwap source interface Vlanif100",
              "desc": "CAPWAP源接口",
              "source": "校园网综合设计实训"
            }
          ],
          "tips": []
        }
      }
    }
  },
  "troubleshooting": {
    "WiFi客户端无法获取IP": {
      "symptom": "AP在线但WiFi设备获取不到IP地址",
      "cause": "AP端口配置为access VLAN100，VLAN101的DHCP Discover报文被丢弃",
      "fix": "AP端口改为trunk模式，PVID设为VLAN100，allow-pass VLAN100到101",
      "verify": "display vlan检查端口PVID和allow-pass",
      "commands": [
        "interface GigabitEthernet0/0/3",
        "port link-type trunk",
        "port trunk pvid vlan 100",
        "port trunk allow-pass vlan 100 to 101"
      ]
    },
    "PC无法ping通网关": {
      "symptom": "Destination host unreachable",
      "cause": "接入交换机端口在错误VLAN，或上行口未放行VLAN",
      "fix": "确认端口划入正确VLAN，确认trunk口放行对应VLAN",
      "verify": "display vlan查看端口所属VLAN",
      "commands": [
        "display vlan",
        "display port vlan"
      ]
    },
    "服务器ping不通": {
      "symptom": "防火墙ARP表显示Incomplete",
      "cause": "服务器端口VLAN与防火墙接口不匹配",
      "fix": "确保服务器端口在正确的VLAN，防火墙接口undo shutdown",
      "verify": "display arp interface GigabitEthernet1/0/0"
    },
    "AP名称错误": {
      "symptom": "AP1被命名为ap2或命名混乱",
      "cause": "AC的WLAN子视图层级太深，quit退出不正确导致命令发到错误上下文",
      "fix": "手动在AC上修正ap-name，确保每次操作后quit退出正确视图",
      "verify": "display ap all"
    },
    "VRRP主备不切换": {
      "symptom": "Master故障后Backup未接管",
      "cause": "VRRP优先级配置错误或vrid不匹配",
      "fix": "确认主设备priority>100，确认两端vrid一致",
      "verify": "display vrrp brief"
    },
    "MSTP实例不一致": {
      "symptom": "交换机间MSTP域不匹配，端口被阻塞",
      "cause": "region-name或revision-level不一致，或忘记active",
      "fix": "所有交换机配置相同的region-name和revision-level，执行active region-configuration",
      "verify": "display stp region-configuration"
    },
    "Hybrid口VLAN不通": {
      "symptom": "Hybrid端口的VLAN流量不通",
      "cause": "PVID和untagged配置不匹配",
      "fix": "确保port hybrid pvid和port hybrid untagged指向正确VLAN",
      "verify": "display port vlan"
    },
    "网络环路广播风暴": {
      "symptom": "网络严重拥塞，交换机CPU飙升",
      "cause": "冗余链路未开启STP导致广播风暴",
      "fix": "所有交换机执行stp enable",
      "verify": "display stp brief"
    },
    "路由器子接口不通": {
      "symptom": "路由器子接口无法与同网段设备通信",
      "cause": "子接口未执行arp broadcast enable",
      "fix": "在子接口下执行arp broadcast enable",
      "verify": "display ip interface brief"
    }
  },
  "config_order": [
    "1. 所有设备: undo t m（关闭日志）→ system-view → undo info-center enable",
    "2. 所有交换机: 创建VLAN（vlan batch）",
    "3. SW1/SW2: MSTP区域配置（region-name + revision-level + instance映射 + active + 根桥）",
    "4. SW1/SW2: DHCP地址池（ip pool + gateway + network + dns）",
    "5. SW1/SW2: VLANIF接口（IP + VRRP主备 + dhcp select global）",
    "6. SW1/SW2: 上行/下行端口配置（trunk/access）",
    "7. SW1/SW2: LACP链路聚合（Eth-Trunk + mode lacp-static）",
    "8. LSW3/LSW4: 汇聚交换机MSTP区域 + 端口配置",
    "9. LSW5~LSW8: 接入交换机端口配置（access划VLAN）",
    "10. LSW9/LSW10: 服务器区/外网区端口配置",
    "11. FW1: 登录 + 接口IP + undo shutdown + 区域划分",
    "12. FW1: 安全策略（trust_to_server, trust_to_untrust, untrust_to_server, server_deny）",
    "13. FW1: OSPF + 默认路由下发",
    "14. AR1: 接口IP + 默认路由",
    "15. SW1/SW2: OSPF配置（等FW1和AR1配好后再开启）",
    "16. AC1: 基础配置（VLAN + CAPWAP + trunk）",
    "17. AC1: WLAN配置（security + ssid + vap + ap-group）",
    "18. AC1: AP注册（ap-mac + ap-sn + ap-group）",
    "19. AP端口: 改为trunk + pvid 100 + allow-pass 100-101",
    "20. 保存所有设备配置（save）"
  ],
  "meta": {
    "version": "2.0",
    "description": "eNSP设备命令经验知识库 - 每次实验积累经验，逐步覆盖所有设备所有命令",
    "design_philosophy": "知识库不是一次性产物，而是随每次实验持续增长的经验库。每次实验后提取新发现的命令、排障经验、最佳实践，写入知识库，使AI工具越来越熟练，最终无需联网即可完成eNSP所有配置。",
    "last_updated": "2026-06-16",
    "experiment_count": 5,
    "total_experiments_recorded": [
      "校园网综合设计实训",
      "实验3-1：以太网基础与VLAN配置",
      "实验3-2：生成树基础实验",
      "实验3-3：链路聚合实验",
      "实验3-4：实现VLAN间通信"
    ]
  },
  "best_practices": {
    "_description": "操作规范 - 每次配置设备前必须遵守",
    "command_rules": [
      {
        "id": "BP-001",
        "rule": "配置前必须检测视图类型",
        "detail": "发送命令前先检测设备当前处于 <> 尖括号（用户视图）还是 [] 方括号（系统视图）。不同视图下可用命令不同，发错视图的命令会报 Unrecognized command 错误。",
        "detection_method": "读取终端提示符：以 > 结尾为用户视图，以 ] 结尾为系统视图",
        "example_user_view": "<LSW1> （用户视图，可执行 display/save/ping/system-view）",
        "example_system_view": "[LSW1] （系统视图，可执行 interface/vlan/ospf 等配置命令）",
        "priority": "critical"
      },
      {
        "id": "BP-002",
        "rule": "配置前第一步：undo terminal monitor",
        "detail": "所有设备配置前必须先执行 undo terminal monitor（简写 undo t m）关闭终端日志监控，否则设备日志会不断弹出干扰命令输入和输出解析。",
        "view": "<> 用户视图",
        "command": "undo terminal monitor",
        "short": "undo t m",
        "priority": "critical"
      },
      {
        "id": "BP-003",
        "rule": "配置完成后必须保存",
        "detail": "所有设备配置完成后必须执行 save 命令保存配置，否则重启后配置丢失。",
        "view": "<> 用户视图",
        "command": "save",
        "priority": "high"
      },
      {
        "id": "BP-004",
        "rule": "防火墙接口默认关闭",
        "detail": "华为USG6000V防火墙所有接口默认shutdown状态，必须手动 undo shutdown 开启。路由器接口默认开启。",
        "applies_to": "USG6000V",
        "priority": "high"
      },
      {
        "id": "BP-005",
