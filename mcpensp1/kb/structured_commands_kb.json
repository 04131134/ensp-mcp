  "system_view_commands": {
    "_meta": {
      "description": "[] 方括号系统视图下的命令",
      "view_indicator": "[设备名]"
    },
    "S5700": {
      "description": "华为S5700系列交换机（核心/汇聚层）",
      "topics": {
        "基础": {
          "view": "[SW-name]",
          "commands": [
            {
              "cmd": "sysname <名称>",
              "desc": "修改主机名"
            },
            {
              "cmd": "undo info-center enable",
              "desc": "关闭信息中心，防日志刷屏，配置前必做"
            },
            {
              "cmd": "vlan batch <vlist>",
              "desc": "批量创建VLAN",
              "example": "vlan batch 10 20 30 40 100 to 101"
            },
            {
              "cmd": "dhcp enable",
              "desc": "全局开启DHCP服务"
            },
            {
              "cmd": "stp mode mstp",
              "desc": "设置STP模式为MSTP"
            }
          ]
        },
        "VLAN端口": {
          "view": "[SW-name-GigabitEthernet0/0/X]",
          "commands": [
            {
              "cmd": "port link-type access",
              "desc": "端口设为access模式"
            },
            {
              "cmd": "port default vlan <id>",
              "desc": "access端口划入指定VLAN"
            },
            {
              "cmd": "port link-type trunk",
              "desc": "端口设为trunk模式"
            },
            {
              "cmd": "port trunk allow-pass vlan <range>",
              "desc": "trunk放行指定VLAN",
              "example": "port trunk allow-pass vlan 2 to 4094"
            },
            {
              "cmd": "port trunk pvid vlan <id>",
              "desc": "设置trunk的PVID（原生VLAN）"
            },
            {
              "cmd": "port link-type hybrid",
              "desc": "端口设为hybrid模式"
            },
            {
              "cmd": "port hybrid pvid vlan <id>",
              "desc": "设置hybrid PVID"
            },
            {
              "cmd": "port hybrid untagged vlan <id>",
              "desc": "hybrid该VLAN不打标签"
            }
          ],
          "tips": [
            "AP端口必须用trunk+PVID，不能用access，否则VLAN101用户流量被丢弃",
            "trunk口默认只放行VLAN1，必须手动allow-pass",
            "access口只能属于一个VLAN"
          ]
        },
        "VLANIF接口": {
          "view": "[SW-name-VlanifX]",
          "commands": [
            {
              "cmd": "interface Vlanif<vlan_id>",
              "desc": "进入VLANIF接口"
            },
            {
              "cmd": "ip address <ip> <mask>",
              "desc": "配置接口IP地址"
            },
            {
              "cmd": "dhcp select global",
              "desc": "启用DHCP全局地址池模式"
            },
            {
              "cmd": "dhcp select interface",
              "desc": "启用DHCP接口地址池模式"
            }
          ]
        },
        "VRRP": {
          "view": "[SW-name-VlanifX]",
          "commands": [
            {
              "cmd": "vrrp vrid <id> virtual-ip <ip>",
              "desc": "配置VRRP虚拟IP（网关地址）"
            },
            {
              "cmd": "vrrp vrid <id> priority <n>",
              "desc": "设置VRRP优先级（>100为Master，默认100）"
            },
            {
              "cmd": "vrrp vrid <id> preempt-mode timer delay <n>",
              "desc": "设置抢占延时"
            }
          ],
          "tips": [
            "VRRP vrid建议与VLAN ID一致便于管理",
            "虚拟IP即为该VLAN的网关地址",
            "主备优先级差建议>=20",
            "SW1主VLAN10/101(优先级120)，备VLAN20/30/40(默认100)",
            "SW2主VLAN20/30/40(优先级120)，备VLAN10/101(默认100)"
          ]
        },
        "MSTP": {
          "view": "[SW-name-mst-region]",
          "commands": [
            {
              "cmd": "stp region-configuration",
              "desc": "进入MST域配置"
            },
            {
              "cmd": "region-name <name>",
              "desc": "MST域名（所有交换机必须一致）",
              "example": "region-name huawei"
            },
            {
              "cmd": "revision-level <n>",
              "desc": "修订等级（所有交换机必须一致）",
              "example": "revision-level 16"
            },
            {
              "cmd": "instance <id> vlan <range>",
              "desc": "实例映射VLAN",
              "example": "instance 1 vlan 10 100 101"
            },
            {
              "cmd": "active region-configuration",
              "desc": "激活MST域配置（必须执行！不执行配置不生效）"
            },
            {
              "cmd": "stp enable",
              "desc": "全局开启STP"
            },
            {
              "cmd": "stp instance <id> root primary",
              "desc": "设为该实例的主根桥"
            },
            {
              "cmd": "stp instance <id> root secondary",
              "desc": "设为该实例的备份根桥"
            }
          ],
          "tips": [
            "region-name + revision-level 必须所有交换机完全一致",
            "active region-configuration 忘记执行是最常见的错误",
            "instance映射规则：10/100/101→instance1，20/30/40→instance2",
            "SW1为instance1主根桥、instance2备份根桥",
            "SW2为instance2主根桥、instance1备份根桥"
          ]
        },
        "DHCP": {
          "view": "[SW-name-ip-pool-xxx]",
          "commands": [
            {
              "cmd": "ip pool <name>",
              "desc": "创建/进入地址池",
              "example": "ip pool vlan10"
            },
            {
              "cmd": "gateway-list <ip>",
              "desc": "网关地址（通常为VRRP VIP）",
              "example": "gateway-list 192.168.1.254"
            },
            {
              "cmd": "network <ip> mask <mask>",
              "desc": "分配网段",
              "example": "network 192.168.1.0 mask 255.255.255.0"
            },
            {
              "cmd": "dns-list <ip>",
              "desc": "DNS服务器地址",
              "example": "dns-list 192.168.0.1"
            },
            {
              "cmd": "excluded-ip-address <start> <end>",
              "desc": "排除地址段",
              "example": "excluded-ip-address 192.168.1.1 192.168.1.10"
            },
            {
              "cmd": "lease day <d> hour <h> minute <m>",
              "desc": "设置租约时间"
            }
          ],
          "tips": [
            "dns-list地址为服务器区DNS服务器IP",
            "网关地址建议使用VRRP虚拟IP"
          ]
        },
        "OSPF": {
          "view": "[SW-name-ospf-1]",
          "commands": [
            {
              "cmd": "ospf 1 router-id <id>",
              "desc": "启动OSPF进程并指定Router-ID",
              "example": "ospf 1 router-id 1.1.1.1"
            },
            {
              "cmd": "area 0.0.0.0",
              "desc": "进入骨干区域Area0"
            },
            {
              "cmd": "network <ip> <wildcard>",
              "desc": "宣告网段",
              "example": "network 192.168.0.0 0.0.255.255"
            },
            {
              "cmd": "silent-interface Vlanif<id>",
              "desc": "静默接口，抑制OSPF报文（防广播浪费）"
            }
          ],
          "tips": [
            "silent-interface用于用户VLAN接口，避免在接入端发送OSPF Hello",
            "network反掩码0.0.255.255匹配192.168.x.0/24网段",
            "静默接口仍可被OSPF宣告，只是不发Hello包"
          ]
        },
        "LACP链路聚合": {
          "view": "[SW-name-Eth-TrunkX]",
          "commands": [
            {
              "cmd": "interface Eth-Trunk <id>",
              "desc": "创建并进入Eth-Trunk接口"
            },
            {
              "cmd": "mode lacp-static",
              "desc": "设置LACP静态模式"
            },
            {
              "cmd": "interface GigabitEthernet0/0/X",
              "desc": "进入物理接口"
            },
            {
              "cmd": "eth-trunk <id>",
              "desc": "将物理接口加入Eth-Trunk"
            },
            {
              "cmd": "port link-type trunk",
              "desc": "聚合口设为trunk"
            },
            {
              "cmd": "port trunk allow-pass vlan 2 to 4094",
              "desc": "聚合口放行所有VLAN"
            }
          ],
          "tips": [
            "Eth-Trunk两端配置必须一致",
            "先创建Eth-Trunk并设mode，再将物理口加入"
          ]
        },
        "Eth-Trunk接口配置": {
          "view": "[SW-name-GigabitEthernet0/0/X]",
          "commands": [
            {
              "cmd": "eth-trunk <id>",
              "desc": "将当前接口加入Eth-Trunk"
            }
          ],
          "tips": [
            "加入Eth-Trunk前确保接口无其他配置"
          ]
        },
        "经验积累": {
          "commands": [
            {
              "cmd": "port link-type hybrid",
              "desc": "端口设为hybrid模式",
              "source": "实验3-1"
            },
            {
              "cmd": "port hybrid untagged vlan <id>",
              "desc": "hybrid口该VLAN不打标签",
              "source": "实验3-1"
            },
            {
              "cmd": "port hybrid pvid vlan <id>",
              "desc": "hybrid口PVID设置",
              "source": "实验3-1"
            },
            {
              "cmd": "mac-vlan enable",
              "desc": "端口启用MAC-VLAN",
              "source": "实验3-1"
            },
            {
              "cmd": "mac-vlan mac-address <mac>",
              "desc": "VLAN下绑定MAC地址",
              "source": "实验3-1"
            },
            {
              "cmd": "shutdown",
              "desc": "关闭接口",
              "source": "实验3-1"
            },
            {
              "cmd": "undo shutdown",
              "desc": "开启接口",
              "source": "实验3-1"
            },
            {
              "cmd": "stp mode stp",
              "desc": "设置STP模式为STP",
              "source": "实验3-2"
            },
            {
              "cmd": "stp root primary",
              "desc": "设为根桥",
              "source": "实验3-2"
            },
            {
              "cmd": "stp root secondary",
              "desc": "设为备份根桥",
              "source": "实验3-2"
            },
            {
              "cmd": "mode manual load-balance",
              "desc": "Eth-Trunk手工模式",
              "source": "实验3-3"
            },
            {
              "cmd": "max active-linknumber <n>",
              "desc": "最大活动链路数",
              "source": "实验3-3"
            },
            {
              "cmd": "least active-linknumber <n>",
              "desc": "最小活动链路数",
              "source": "实验3-3"
            },
            {
              "cmd": "load-balance dst-ip",
              "desc": "负载分担模式",
              "source": "实验3-3"
            }
          ],
          "tips": []
        }
      }
    },
    "S3700": {
      "description": "华为S3700系列交换机（接入层，二层交换机）",
      "topics": {
        "基础": {
          "view": "[LSW-name]",
          "commands": [
            {
              "cmd": "sysname <名称>",
              "desc": "修改主机名"
            },
            {
              "cmd": "undo info-center enable",
              "desc": "关闭信息中心"
            },
            {
              "cmd": "vlan batch <id>",
              "desc": "创建VLAN",
              "example": "vlan batch 10"
            }
          ]
        },
        "端口配置": {
          "view": "[LSW-name-Ethernet0/0/X]",
          "commands": [
            {
              "cmd": "port link-type access",
              "desc": "接入模式"
            },
            {
              "cmd": "port default vlan <id>",
              "desc": "划入指定VLAN"
            }
          ],
          "tips": [
            "S3700端口命名：Ethernet0/0/1~22（百兆），GE0/0/1~2（千兆上行）",
            "S3700只支持二层，不能配三层接口",
            "接入层交换机只需要access端口划VLAN即可"
          ]
        },
        "上行口配置": {
          "view": "[LSW-name-GigabitEthernet0/0/X]",
          "commands": [
            {
              "cmd": "port link-type trunk",
              "desc": "上行口设为trunk"
            },
            {
              "cmd": "port trunk allow-pass vlan <range>",
              "desc": "放行VLAN",
              "example": "port trunk allow-pass vlan 10 100 to 101"
            }
          ],
          "tips": [
            "S3700的GE口通常用于上行连接汇聚交换机",
            "上行trunk口需放行管理VLAN和业务VLAN"
          ]
        }
      }
    },
    "USG6000V": {
      "description": "华为USG6000V系列防火墙",
      "login": "默认用户名admin，默认密码admin@123",
      "topics": {
        "接口配置": {
          "view": "[FW-GigabitEthernetX/0/X]",
          "commands": [
            {
              "cmd": "undo shutdown",
              "desc": "开启端口（防火墙接口默认shutdown）"
            },
            {
              "cmd": "ip address <ip> <mask>",
              "desc": "配置接口IP",
              "example": "ip address 192.168.100.2 255.255.255.0"
            },
            {
              "cmd": "service-manage ping permit",
              "desc": "允许ping管理访问"
            },
            {
              "cmd": "service-manage https permit",
              "desc": "允许HTTPS管理访问"
            },
            {
              "cmd": "service-manage http permit",
              "desc": "允许HTTP管理访问"
            }
          ],
          "tips": [
            "防火墙接口默认shutdown，必须手动undo shutdown",
            "需要service-manage permit才能从该接口管理防火墙"
          ]
        },
        "安全区域": {
          "view": "[FW-zone-xxx]",
          "commands": [
            {
              "cmd": "firewall zone trust",
              "desc": "进入Trust区域"
            },
            {
              "cmd": "firewall zone untrust",
              "desc": "进入Untrust区域"
            },
            {
              "cmd": "firewall zone dmz",
              "desc": "进入DMZ区域"
            },
            {
              "cmd": "firewall zone name <name>",
              "desc": "创建自定义区域"
            },
            {
              "cmd": "set priority <n>",
              "desc": "设置区域优先级"
            },
            {
              "cmd": "add interface <if>",
              "desc": "将接口加入区域",
              "example": "add interface GigabitEthernet1/0/0"
            }
          ],
          "tips": [
            "默认优先级：trust(85) > dmz(50) > untrust(5)",
            "高优先级→低优先级默认放行（trust→untrust）",
            "低优先级→高优先级默认拒绝（untrust→trust需配策略）",
            "Trust区：内网用户；Untrust区：外网；DMZ区：服务器"
          ]
        },
        "安全策略": {
          "view": "[FW-security-policy]",
          "commands": [
            {
              "cmd": "security-policy",
              "desc": "进入安全策略视图"
            },
            {
              "cmd": "rule name <name>",
              "desc": "创建/进入策略规则",
              "example": "rule name trust_to_server"
            },
            {
              "cmd": "source-zone <zone>",
              "desc": "指定源区域",
              "example": "source-zone trust"
            },
            {
              "cmd": "destination-zone <zone>",
              "desc": "指定目的区域"
            },
            {
              "cmd": "source-address <ip> <mask>",
              "desc": "指定源地址"
            },
            {
              "cmd": "destination-address <ip> <mask>",
              "desc": "指定目的地址"
            },
            {
              "cmd": "service icmp",
              "desc": "允许ICMP服务"
            },
            {
              "cmd": "service http",
              "desc": "允许HTTP服务"
            },
            {
              "cmd": "service ftp",
              "desc": "允许FTP服务"
            },
            {
              "cmd": "service dns",
              "desc": "允许DNS服务"
            },
            {
              "cmd": "action permit",
              "desc": "允许通过"
            },
            {
              "cmd": "action deny",
              "desc": "拒绝通过"
            }
          ],
          "tips": [
            "默认策略是deny（拒绝所有）",
            "规则从上到下匹配，顺序很重要",
            "状态检测机制：回程流量自动放行",
            "本实验策略：①内外可访问服务器和外网 ②外网只能访问服务器 ③服务器只能被访问不能主动发起"
          ]
        },
        "OSPF路由": {
          "view": "[FW-ospf-1]",
          "commands": [
            {
              "cmd": "ospf 1 router-id <id>",
              "desc": "启动OSPF"
            },
            {
